# -----------------------------
# DEV ONLY (localhost defaults)
# -----------------------------
NODE_ENV=development
API_PORT=4000
WS_PORT=4001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collab
DB_USER=collab
DB_PASSWORD=change_me_dev_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------
# PROD REQUIRED (set real values on VPS)
# -------------------------------------
APP_DOMAIN=example.com
NEXT_PUBLIC_APP_URL=https://example.com
# URL API без /api в конце (бэкенд слушает корень: /auth/login, /health и т.д.)
NEXT_PUBLIC_API_URL=https://example.com
NEXT_PUBLIC_WS_URL=wss://example.com/ws
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.example.com
# Cloudinary (фото/видео в чат). Для unsigned upload нужны только cloud name и preset.
# CLOUDINARY_API_SECRET — только на сервере, НИКОГДА не NEXT_PUBLIC (не в бандл).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=collab_unsigned
# Опционально: NEXT_PUBLIC_CLOUDINARY_API_KEY — только если нужен в клиенте для других сценариев (не для upload).
# NEXT_PUBLIC_GIPHY_API_KEY=your_giphy_api_key

DATABASE_URL=postgresql://collab:change_me_prod_password@postgres:5432/collab?sslmode=disable
REDIS_URL=redis://redis:6379

JWT_SECRET=replace_with_very_long_random_secret
JWT_REFRESH_SECRET=replace_with_very_long_random_refresh_secret
WS_JWT_SECRET=replace_with_same_or_compatible_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
AUTH_REFRESH_COOKIE_NAME=collab_refresh
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=none
AUTH_BEARER_ISSUER=collab-api
AUTH_BEARER_AUDIENCE=collab-web

CORS_ORIGIN=https://example.com
WS_ALLOWED_ORIGIN=https://example.com

LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace_with_livekit_api_key
LIVEKIT_API_SECRET=replace_with_livekit_api_secret

# Optional
MEDIA_PUBLIC_BASE_URL=https://example.com/media

# App/API limits (message length, file size, pagination, rate limits, etc.) are defined in code:
# - lib/constants.ts (app)
# - services/api/src/constants.ts (API, keep in sync with lib)
