{
  "name": "websocket-gateway",
  "version": "1.0.0",
  "description": "WebSocket gateway for Collab realtime (Redis pub/sub)",
  "type": "module",
  "main": "dist/services/websocket-gateway/src/server.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/services/websocket-gateway/src/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.3.2",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
