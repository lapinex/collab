## WebSocket Gateway Environment Variables
# Copy to .env.gateway (local only, never commit secrets)

# Runtime
PORT=4001
NODE_ENV=production

# Auth
WS_JWT_SECRET=replace_with_long_random_secret
WS_ALLOWED_ORIGIN=https://example.com

# Database
DATABASE_URL=postgresql://collab:replace_with_password@postgres:5432/collab?sslmode=disable

# Redis (priority: WS_REDIS_URL > REDIS_URL)
WS_REDIS_URL=redis://redis:6379
# REDIS_URL=redis://redis:6379

# Optional idempotency tuning
# WS_NONCE_TTL_MS=60000
# WS_NONCE_MAX_ENTRIES=10000

